{
  "name": "clocked-backend",
  "version": "1.0.0",
  "description": "Clocked API - anonymous employer review platform",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "db:generate": "prisma generate --schema=../prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema=../prisma/schema.prisma",
    "db:push": "prisma db push --schema=../prisma/schema.prisma",
    "db:seed": "node ../prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.4",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "google-auth-library": "^10.6.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.20.0",
    "prisma": "^5.10.0",
    "socket.io": "^4.8.3",
    "stripe": "^14.19.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
