generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String         @id @default(cuid())
  anonymous_id      String         @unique @default(cuid())
  email             String?        @unique
  password_hash     String?
  google_id         String?        @unique
  created_at        DateTime       @default(now())
  subscription_status SubscriptionStatus @default(FREE)
  anon_number     Int?           @unique
  display_name      String?
  username          String?        @unique
  avatar_url        String?
  follower_count    Int            @default(0)
  following_count   Int            @default(0)

  posts         Post[]
  comments      Comment[]
  saves         Save[]
  flags         Flag[]
  reactions     PostReaction[]
  subscription  Subscription?
  notifications   Notification[]
  companyRatings  CompanyRating[]
  followers         Follow[] @relation("following")
  following         Follow[] @relation("follower")
  commentLikes      CommentLike[]

  @@map("users")
}

model Follow {
  id           String   @id @default(cuid())
  follower_id  String
  following_id String
  created_at   DateTime @default(now())

  follower  User @relation("follower", fields: [follower_id], references: [id])
  following User @relation("following", fields: [following_id], references: [id])

  @@unique([follower_id, following_id])
  @@map("follows")
}

model Post {
  id               String   @id @default(cuid())
  anonymous_user_id String
  employer_place_id String
  employer_name    String
  employer_address String
  rating_emoji     RatingEmoji
  header           String?
  body             String
  media_urls       String[]
  likes            Int      @default(0)
  dislikes         Int      @default(0)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  user     User       @relation(fields: [anonymous_user_id], references: [id])
  comments Comment[]
  saves    Save[]
  flags    Flag[]
  reactions PostReaction[]

  @@index([employer_place_id])
  @@index([created_at(sort: Desc)])
  @@map("posts")
}

model Comment {
  id               String   @id @default(cuid())
  post_id          String
  anonymous_user_id String
  body             String
  image_url        String?
  parent_id        String?
  likes            Int      @default(0)
  created_at       DateTime @default(now())

  post     Post          @relation(fields: [post_id], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [anonymous_user_id], references: [id])
  parent   Comment?      @relation("replies", fields: [parent_id], references: [id])
  replies  Comment[]     @relation("replies")
  likes_rel CommentLike[]

  @@index([post_id])
  @@map("comments")
}

model CommentLike {
  id         String   @id @default(cuid())
  user_id    String
  comment_id String
  created_at DateTime @default(now())

  user    User    @relation(fields: [user_id], references: [id])
  comment Comment @relation(fields: [comment_id], references: [id], onDelete: Cascade)

  @@unique([user_id, comment_id])
  @@map("comment_likes")
}

model Save {
  id      String @id @default(cuid())
  user_id String
  post_id String

  user User @relation(fields: [user_id], references: [id])
  post Post @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@unique([user_id, post_id])
  @@map("saves")
}

model PostReaction {
  id      String @id @default(cuid())
  user_id String
  post_id String
  type    String // 'like' or 'dislike'
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])
  post Post @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@unique([user_id, post_id])
  @@map("post_reactions")
}

model Flag {
  id      String @id @default(cuid())
  user_id String
  post_id String
  reason  String
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])
  post Post @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@unique([user_id, post_id])
  @@map("flags")
}

model Subscription {
  id                 String             @id @default(cuid())
  user_id            String             @unique
  stripe_customer_id String             @unique
  stripe_sub_id      String?
  status             SubscriptionStatus @default(FREE)
  trial_end          DateTime?
  current_period_end DateTime?
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@map("subscriptions")
}

model CompanyRating {
  id         String   @id @default(cuid())
  user_id    String
  place_id   String
  rating     Int      // 1-5
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@unique([user_id, place_id])
  @@index([place_id])
  @@map("company_ratings")
}

model Notification {
  id         String   @id @default(cuid())
  user_id    String
  type       String
  message    String
  read       Boolean  @default(false)
  data       Json?
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("notifications")
}

enum RatingEmoji {
  BAD
  NEUTRAL
  GOOD
}

enum SubscriptionStatus {
  FREE
  TRIALING
  ACTIVE
  CANCELED
  PAST_DUE
}
